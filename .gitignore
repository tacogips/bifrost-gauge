# Dependencies
node_modules/

# Build output
dist/
ui/dist/
.build/
*.tsbuildinfo

# Bun (binary lockfile - we use text lockfile bun.lock instead)
bun.lockb

# Environment files
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Nix
.direnv/
result
/result-*
/.pre-commit-config.yaml

# Logs
logs/
*.log
npm-debug.log*

# Release artifacts
release/*.app/
release/*.zip
release/*.sha256
release/*.dmg

# Test coverage
coverage/
playwright-report/
test-results/

# Temporary files
tmp/
temp/
.cache/
telegram-sdk/

# Implementation progress lock file
impl-plans/.progress.lock

# Private files
**/.envrc.private*
.private*/

# rielflow runtime artifacts and session store (default paths)
.rielflow/
.rielflow-data/
.rielflow-data/**
.rielflow-opt/
.rielflow-opt/**
.rielflow-artifact/
.rielflow-artifact/**
.rielflow-datas/
.rielflow-datas/**

# Bifrost persists runtime state beside config.json in its app-dir.
bifrost/*.db
bifrost/*.db-*
bifrost/*.sqlite
bifrost/*.sqlite-*
bifrost/logs/

# Local temporary Bifrost check runtime.
/.run-*
