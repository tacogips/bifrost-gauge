# Copy to .env and fill in real values before making provider calls:
#   cp .env.example .env
#
# Generate an encryption key for local use, for example:
#   openssl rand -base64 32
BIFROST_ENCRYPTION_KEY=change-me-generate-with-openssl-rand-base64-32

# Local Bifrost service settings.
BIFROST_IMAGE_TAG=latest
BIFROST_BIND_HOST=127.0.0.1
BIFROST_PORT=18080
BIFROST_LOG_LEVEL=info
BIFROST_LOG_STYLE=pretty

# Local personal virtual key. Use this value as your API key when calling Bifrost.
BIFROST_VK_PERSONAL=local-personal-vk-change-me

# Provider credentials. Keep empty until you use that provider.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
